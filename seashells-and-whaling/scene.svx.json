  "metas": [
    {
      "collection": {
        "titles": { "EN": "Seashells &amp; Whaling Grounds" },
        "intros": {
          "EN": "This Scene overlays a map of whaling grounds from the David Rumsey Historic Map Collection with 3D models of seashells from the New Bedford Whaling Museum. The map supports the digital models to show places where these animals may be found around the world.  Charlotte Sherman DeHart's Logbook of the Roman 2nd (ship) of New Bedford supports the illustrative map through the narrative of her voyage aboard the whaling ship during 1857-1861."
        }
